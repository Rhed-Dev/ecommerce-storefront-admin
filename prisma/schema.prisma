// Prisma schema for the e-commerce storefront + admin panel.
// Money is always stored as integer cents — see README "Implementation highlights".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum InventoryChangeKind {
  SALE
  MANUAL
  RESTOCK
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  image        String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  orders       Order[]
  carts        Cart[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String
  featured    Boolean          @default(false)
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
}

model ProductVariant {
  id                String         @id @default(cuid())
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String // e.g. "M / Black" — flattened size/color option
  sku               String         @unique
  priceCents        Int // integer cents; never floats
  stock             Int            @default(0)
  lowStockThreshold Int            @default(5)
  cartItems         CartItem[]
  orderItems        OrderItem[]
  inventoryLogs     InventoryLog[]

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  publicId  String // Cloudinary public id
  url       String // resolved delivery URL (stored so rendering never needs API credentials)
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime       @default(now())

  @@unique([cartId, variantId])
}

model Order {
  id              String      @id @default(cuid())
  number          Int         @unique @default(autoincrement())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String
  status          OrderStatus @default(PENDING)
  subtotalCents   Int
  shippingCents   Int         @default(0)
  totalCents      Int
  stripeSessionId String?     @unique
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  // Snapshots taken at purchase time — orders must never reference live prices.
  productName    String
  variantName    String
  unitPriceCents Int
  quantity       Int
}

model InventoryLog {
  id        String              @id @default(cuid())
  variantId String
  variant   ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  delta     Int // positive = stock added, negative = stock removed
  kind      InventoryChangeKind
  reason    String?
  orderId   String?
  createdAt DateTime            @default(now())

  @@index([variantId])
}

// Stripe webhook idempotency ledger: each event id is recorded exactly once,
// so replayed/retried webhook deliveries become no-ops.
model ProcessedStripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}
