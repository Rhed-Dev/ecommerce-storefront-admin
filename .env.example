# PostgreSQL connection string (matches the database started by docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/storefront

# Canonical app URL used by NextAuth for callbacks/redirects
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign NextAuth JWT sessions (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Public base URL used to build Stripe success/cancel redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe secret API key (test-mode key from the Stripe dashboard)
STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe webhook signing secret (from `stripe listen` or the dashboard webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# OPTIONAL: Google OAuth client id — the Google sign-in button is hidden when unset
GOOGLE_CLIENT_ID=

# OPTIONAL: Google OAuth client secret
GOOGLE_CLIENT_SECRET=

# Cloudinary cloud name (safe to expose; used to build the browser upload URL)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key (paired with the server-generated signature)
CLOUDINARY_API_KEY=cloudinary-api-key

# Cloudinary API secret — never exposed to the browser; used to sign uploads server-side
CLOUDINARY_API_SECRET=cloudinary-api-secret
